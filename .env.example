NODE_ENV=development
PORT=3000
TZ=Asia/Kolkata

# Neon Connection Strings
# For Sandbox/Dev: postgres://user:pass@ep-host-123.region.aws.neon.tech/nudgeflow-dev?sslmode=require
# For Production: postgres://user:pass@ep-host-456.region.aws.neon.tech/nudgeflow-prod?sslmode=require
DATABASE_URL=postgres://user:password@host/database?sslmode=require

OPENAI_API_KEY=replace_me
OPENAI_MODEL_ROUTINE=gpt-5-mini
OPENAI_MODEL_COMPLEX=gpt-5.1

SARVAM_API_KEY=replace_me
SARVAM_BASE_URL=https://api.sarvam.ai

GUPSHUP_API_KEY=replace_me
GUPSHUP_APP_NAME=replace_me
GUPSHUP_BASE_URL=https://api.gupshup.io

LENDER_STATUS_API_BASE_URL=https://sandbox.lender.local
LENDER_STATUS_API_KEY=replace_me

AGENT_SKILLS_DIR=skills
# Tenant ID controls which folder under tenants/ is loaded at runtime.
# To add a new company: create tenants/<id>/ with SOUL.md, channel-rules.md, knowledge-base.md, and data/
TENANT_ID=clickpe
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
DASHBOARD_AUTH_SECRET=change_me_please
