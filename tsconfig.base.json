{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@nudges/channel-gupshup": ["packages/channel-gupshup/src/index.ts"],
      "@nudges/config": ["packages/config/src/index.ts"],
      "@nudges/db": ["packages/db/src/index.ts"],
      "@nudges/domain": ["packages/domain/src/index.ts"],
      "@nudges/knowledge-runtime": ["packages/knowledge-runtime/src/index.ts"],
      "@nudges/observability": ["packages/observability/src/index.ts"],
      "@nudges/persuasion-core": ["packages/persuasion-core/src/index.ts"],
      "@nudges/provider-openai": ["packages/provider-openai/src/index.ts"],
      "@nudges/provider-bolna": ["packages/provider-bolna/src/index.ts"],
      "@nudges/provider-sarvam": ["packages/provider-sarvam/src/index.ts"],
      "@nudges/safety-compliance": ["packages/safety-compliance/src/index.ts"],
      "@nudges/session-memory": ["packages/session-memory/src/index.ts"]
    }
  }
}
