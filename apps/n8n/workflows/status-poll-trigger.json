{
  "name": "status-poll-trigger",
  "nodes": [
    {
      "id": "schedule",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [220, 240],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 30
            }
          ]
        }
      }
    },
    {
      "id": "status-poll",
      "name": "Call Status Sync",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [520, 240],
      "parameters": {
        "method": "POST",
        "url": "={{$env.STATUS_SYNC_WORKER_URL}}/status-sync/poll",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{$json}}"
      }
    }
  ],
  "connections": {
    "Schedule Trigger": {
      "main": [
        [
          {
            "node": "Call Status Sync",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
